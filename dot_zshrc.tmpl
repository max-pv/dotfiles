# Oh My Zsh
export ZSH="$HOME/.oh-my-zsh"
plugins=(git)
source $ZSH/oh-my-zsh.sh

# PATH
export PATH="$HOME/.local/bin:$PATH"
export PATH="$PATH:$HOME/.bin"
export PATH="$PATH:$HOME/go/bin"

{{- if .work_git_host }}

# Work config
export GOPRIVATE="{{ .work_git_host }}/*"
{{- end }}

# Load secrets if exists
[ -f ~/.secrets ] && source ~/.secrets

# mise (manages node, go, python, etc.)
eval "$(mise activate zsh)"

# Starship prompt
eval "$(starship init zsh)"

# Blank line after each command (skip first prompt)
_first_prompt=true
precmd() {
  if $_first_prompt; then
    _first_prompt=false
  else
    echo
  fi
}
alias clear='_first_prompt=true; command clear'

# Aliases
alias gco='git checkout'
alias ga='git add'
alias gc='git commit'
alias gw='git worktree'
alias dko='docker rm -f $(docker ps -a -q)'

# SSH agent
eval "$(ssh-agent -s)" > /dev/null 2>&1
ssh-add ~/.ssh/id_ecdsa 2>/dev/null

# Machine-specific config (not tracked)
[ -f ~/.zshrc.local ] && source ~/.zshrc.local
